GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=sqlite+aiosqlite:///./chess_analyzer.db
SECRET_KEY=generate-with: python -c "import secrets; print(secrets.token_hex(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=optional_webhook_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=chessaicoach.contact@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM_EMAIL=chessaicoach.contact@gmail.com
PAYMENT_ADMIN_EMAIL=chessaicoach.contact@gmail.com
TRANSACTIONAL_EMAILS_ENABLED=false
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
ENVIRONMENT=development
DASHBOARD_PRO_LOCK_ENABLED=true
PRO_MONTHLY_PRICE_INR=50
COACHING_HOURLY_PRICE_INR=500
COACHING_MONTHLY_10_PRICE_INR=5000
DASHBOARD_PRO_STOCKFISH_MAX_GAMES=25
DASHBOARD_PRO_STOCKFISH_DEPTH=18
DASHBOARD_PRO_STOCKFISH_FALLBACK_DEPTH=14
